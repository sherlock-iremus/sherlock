									"numoutlets" : 0,
									"patching_rect" : [ 533.0, 292.0, 356.0, 25.0 ],
									"text" : "• turn the munger on and off, to save CPU. (1) by default."
								}

							}
, 							{
								"box" : 								{
									"bubble" : 1,
									"fontname" : "Arial",
									"fontsize" : 13.0,
									"id" : "obj-100",
